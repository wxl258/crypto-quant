# CryptoQuant EditorConfig
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,html,css,js}]
indent_size = 2

[*.{kt,kts}]
indent_size = 4

[*.{md,rst}]
trim_trailing_whitespace = false

[*.{xml,gradle}]
indent_size = 4

[Makefile]
indent_style = tab
